NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only. Never expose this in browser code.
SUPABASE_SECRET_KEY=your-secret-or-service-role-key

# Secret that guards the scheduled order sync (GET /api/sync-orders).
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
# Other schedulers can pass it as a `?secret=` query param. Leave unset to
# disable the scheduled trigger entirely.
CRON_SECRET=

# Optional integrations for later sync workers.
CULTIVERA_USERNAME=
CULTIVERA_PASSWORD=
CULTIVERA_EXPORT_PAYLOAD_JSON=
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
# Legacy alias from V1, also accepted by the route-line API.
GOOGLE_MAPS_API_KEY=
